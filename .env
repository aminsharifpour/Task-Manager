PORT=8787
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
SERVE_CLIENT=false
DB_MODE=postgres
DATABASE_URL=postgresql://taskapp:change-this-postgres-password@127.0.0.1:5432/tasks_app?schema=public

POSTGRES_DB=tasks_app
POSTGRES_USER=taskapp
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_PORT=5432

API_PORT=8787
WEB_PORT=8080

# اگر فرانت را جدا سرو می‌کنی این Origin را ست کن. در docker-compose فعلی لازم نیست.
# CORS_ORIGIN=https://app.example.com
