{
  "name": "tasks",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:full",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --config apps/web/vite.config.ts --host 0.0.0.0 --port 5180 --strictPort",
    "dev:api": "JWT_SECRET=${JWT_SECRET:-dev-local-secret} node apps/api/src/index.js",
    "build": "tsc -p apps/web/tsconfig.json && vite build --config apps/web/vite.config.ts",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "start:api": "JWT_SECRET=${JWT_SECRET:-dev-local-secret} node apps/api/src/index.js",
    "preview:web": "vite preview --config apps/web/vite.config.ts --host 0.0.0.0 --port 4173 --strictPort",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema apps/api/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema apps/api/prisma/schema.prisma",
    "db:migrate-json": "node apps/api/scripts/migrate-json-to-postgres.mjs",
    "db:bootstrap-postgres": "node apps/api/scripts/bootstrap-postgres.mjs",
    "test:e2e": "node tests/e2e/main.mjs",
    "preview": "vite preview --config apps/web/vite.config.ts",
    "start": "JWT_SECRET=${JWT_SECRET:-dev-local-secret} node apps/api/src/index.js"
  },
  "devDependencies": {
    "@types/jalaali-js": "^1.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "animate-ui": "^0.0.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jalaali-js": "^1.2.8",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  }
}
