PORT=8787
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
SERVE_CLIENT=false
DB_MODE=json
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/tasks_app?schema=public
# اگر فرانت و بک‌اند روی دامنه جدا هستند، Origin فرانت را اینجا بگذار.
# CORS_ORIGIN=https://app.example.com
# Optional first-run bootstrap admin
# TASK_APP_DEFAULT_ADMIN_PHONE=09120000000
# TASK_APP_DEFAULT_ADMIN_PASSWORD=ChangeThisStrongPassword
